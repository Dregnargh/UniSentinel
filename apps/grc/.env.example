# UniSentinel GRC platform — configuration
# Copy to .env for local development (`next dev` reads it automatically).

# PostgreSQL connection. Local dev:
#   docker run --name unisentinel-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=unisentinel_grc -p 5433:5432 -d postgres:16
DATABASE_URL=postgres://postgres:postgres@localhost:5433/unisentinel_grc
# Local Postgres has no TLS; leave unset (or remove) in production.
DATABASE_SSL=false
# Verified TLS: paste the CA bundle PEM (e.g. RDS global bundle) to enable
# certificate verification.
# DATABASE_CA_CERT=

# Session signing secret. REQUIRED in production (the server refuses to start
# sessions without it). Generate with: openssl rand -base64 32
AUTH_SECRET=

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Overrides the version reported by /healthz (set by the Docker build).
# APP_VERSION=

# Optional dedicated key for secrets-at-rest encryption (SMTP passwords,
# connector credentials). Falls back to AUTH_SECRET when unset.
# SECRET_KEY=

# File storage (company logo now; evidence files later). local = directory tree.
FILE_STORAGE=local
FILE_STORAGE_PATH=./data/files

# License verification public key (PEM or base64 PEM). Generate a signing pair
# with: node deploy/licensing/keygen.mjs   (see deploy/licensing/README.md)
# LICENSE_PUBLIC_KEY=
