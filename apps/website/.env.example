# --- Database (PostgreSQL / AWS RDS) ---
# Full Postgres connection string.
# Local dev (e.g. Docker Postgres): add DATABASE_SSL=false to skip TLS.
DATABASE_URL=postgres://user:password@localhost:5432/unisentinel
# Production (AWS RDS): use the RDS endpoint, e.g.
# DATABASE_URL=postgres://admin:password@unisentinel.abcdef.us-east-1.rds.amazonaws.com:5432/unisentinel

# TLS. RDS requires TLS (leave DATABASE_SSL unset in prod).
# Set to false ONLY for a plaintext local Postgres.
# DATABASE_SSL=false
# Recommended for prod: verify the RDS server cert by pasting the RDS CA bundle
# (https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem) here.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Max connections per server instance. Keep small on serverless; prefer an
# RDS Proxy in front of RDS.
# DATABASE_POOL_MAX=5

# --- Auth ---
# Secret used to sign session cookies. REQUIRED in production.
# Generate one: openssl rand -base64 32   (or: node -e "console.log(crypto.randomBytes(32).toString('base64'))")
AUTH_SECRET=replace-with-a-long-random-secret
