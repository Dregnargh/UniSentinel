{
  "name": "unisentinel",
  "private": true,
  "version": "0.1.0",
  "description": "UniSentinel monorepo: GRC platform (apps/grc), marketing site + internal CRM (apps/website), design system (packages/ui).",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:ui": "npm run build -w @unisentinel/ui",
    "build:grc": "npm run build -w @unisentinel/grc",
    "build:website": "npm run build -w website",
    "dev:grc": "npm run dev -w @unisentinel/grc",
    "typecheck": "npm run typecheck -w @unisentinel/ui -w @unisentinel/db -w @unisentinel/grc",
    "test": "npm run test -w @unisentinel/grc",
    "db:generate": "npm run generate -w @unisentinel/db",
    "db:migrate": "npm run migrate -w @unisentinel/db"
  },
  "engines": {
    "node": ">=22"
  }
}
