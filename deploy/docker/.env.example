# UniSentinel self-hosted stack — copy to .env next to compose.yaml.
# ./install.sh fills the two secrets in automatically on first install.

# REQUIRED. Postgres superuser password (container-internal network only).
POSTGRES_PASSWORD=change-me

# REQUIRED. Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-too

# Host port the web UI listens on.
WEB_PORT=8080

# Session cookie Secure attribute. Keep true when a TLS reverse proxy fronts
# this stack (recommended). Set to false ONLY for plain-HTTP LAN access —
# browsers refuse Secure cookies from non-HTTPS origins (localhost excepted)
# and login breaks.
COOKIE_SECURE=true

# debug | info | warn | error
LOG_LEVEL=info

# Product image. TAG is stamped by the release bundle and moved by upgrade.sh.
IMAGE=ghcr.io/dregnargh/unisentinel
TAG=latest
POSTGRES_IMAGE=postgres:16

# base64 PEM of your license-verification public key (deploy/licensing/README.md)
LICENSE_PUBLIC_KEY=
