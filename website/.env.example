# --- Database (libSQL / SQLite) ---
# Local dev: a file (zero setup).
DATABASE_URL=file:./dev.db
# Production (Turso): set these to your Turso DB URL + token instead.
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# --- Auth ---
# Secret used to sign session cookies. REQUIRED in production.
# Generate one: openssl rand -base64 32   (or: node -e "console.log(crypto.randomBytes(32).toString('base64'))")
AUTH_SECRET=replace-with-a-long-random-secret
