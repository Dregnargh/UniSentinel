{
  "name": "@unisentinel/db",
  "version": "0.1.0",
  "private": true,
  "description": "UniSentinel GRC platform database: drizzle schema + versioned SQL migrations.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "node scripts/migrate.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  }
}
